<IfModule mod_rewrite.c>
RewriteEngine On

# 1. Fortam HTTPS si non-WWW intr-un singur pas (evitam redirect chains)
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^(.*)$ https://just-sitting.com/$1 [L,R=301,NE]

# 2. Domeniul fara sufix de limba merge pe varianta implicita EN (301 permanent).
RewriteRule ^$ https://just-sitting.com/en [R=301,L]

# Compatibilitate pentru favicon la radacina domeniului.
RewriteRule ^favicon\.ico$ imgs/favicon.ico [L,NC]

# Redirectionam vechile URL-uri cu .php indexate din greseala (ex: /en/contact.php -> /en/contact)
RewriteRule ^(ro|en)/([^/]+)\.php$ https://just-sitting.com/$1/$2 [L,R=301,NC]

# Pastram accesul direct la fisierele existente.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Homepage pe limba.
RewriteRule ^(ro|en)/?$ index.php?l=$1 [L,QSA,NC]

# Acceptam si varianta veche, dar PHP va face redirect catre slugul canonic.
RewriteRule ^(ro|en)/(calea|path)/?$ calea.php?l=$1 [L,QSA,NC]
RewriteRule ^(ro|en)/(just-sitting)/?$ just-sitting.php?l=$1 [L,QSA,NC]
RewriteRule ^(ro|en)/(invatatura|wisdom)/?$ invatatura.php?l=$1 [L,QSA,NC]
RewriteRule ^(ro|en)/(contact)/?$ contact.php?l=$1 [L,QSA,NC]

# Politici legale
RewriteRule ^(ro|en)/(politica-confidentialitate|privacy-policy)/?$ privacy-policy.php?l=$1 [L,QSA,NC]
RewriteRule ^(ro|en)/(politica-cookies|cookies-policy)/?$ cookies-policy.php?l=$1 [L,QSA,NC]
RewriteRule ^(ro|en)/(termeni-conditii|terms-conditions)/?$ terms.php?l=$1 [L,QSA,NC]
</IfModule>
